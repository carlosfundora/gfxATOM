# Shared AMD ROCm/GFX1030 CI environment contract.
# Source this from self-hosted runner workflows and local smoke scripts.

HSA_OVERRIDE_GFX_VERSION=10.3.0
AMDGPU_TARGETS=gfx1030
PYTORCH_ROCM_ARCH=gfx1030
ROCM_PATH=/opt/rocm
HIP_PATH=/opt/rocm
VLLM_TARGET_DEVICE=rocm
FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE
